# ===============================================
#  iDempiere 8.2 — Entorno aislado (direnv + zsh)
#  Base = carpeta donde vive ESTE .envrc
# ===============================================

# --- Detectar BASE (carpeta del .envrc) ---
_ENVRC_FILE="$(find_up .envrc)"
BASE="$(cd "$(dirname "$_ENVRC_FILE")" && pwd)"
export IDEM8_ROOT="$BASE"

# --- Layout esperado (solo carpetas; contenido lo copias tú) ---
export MAVEN_HOME="$BASE/apache-maven-3.6.3"     # carpeta (adentro copiarás Maven)
export ECLIPSE_HOME="$BASE/eclipse"              # carpeta (adentro copiarás Eclipse)
export IDEMPIERE_HOME="$BASE/sources/idempiere"  # repo/clon de iDempiere 8.2

# --- Extras solicitados / compatibilidad scripts ---
export IDEMPIERE_REPO="$IDEMPIERE_HOME"          # solicitado
export IDEMPIERE_REPOSITORY="$IDEMPIERE_HOME"    # algunos scripts piden este nombre

# --- Workspace/P2 aislado ---
export ECLIPSE_WORKSPACE="$BASE/workspace-8"
export ECLIPSE_P2="$BASE/.p2"

# --- Maven aislado (repo + settings) ---
export MVN_LOCAL_REPO="$BASE/.m2/repository"
export MAVEN_USER_SETTINGS="$BASE/.m2/settings.xml"
export M2_HOME="$MAVEN_HOME"

# --- Java 11 (autodetección con fallback) ---
JAVA_CANDIDATES=(
  "/usr/lib/jvm/java-11-openjdk-amd64"
  "/usr/lib/jvm/java-1.11.0-openjdk-amd64"
  "/usr/lib/jvm/openjdk-11"
)
unset JAVA_HOME
for j in "${JAVA_CANDIDATES[@]}"; do
  if [[ -x "$j/bin/java" ]]; then
    export JAVA_HOME="$j"
    break
  fi
done

# --- Crear estructura mínima requerida ---
mkdir -p \
  "$BASE/.m2/repository" \
  "$BASE/.mvn" \
  "$BASE/.p2" \
  "$BASE/sources" \
  "$BASE/workspace-8" \
  "$BASE/apache-maven-3.6.3" \
  "$BASE/eclipse"

# Si ya existe el repo de iDempiere, asegura su .mvn/
if [[ -d "$IDEMPIERE_HOME" ]]; then
  mkdir -p "$IDEMPIERE_HOME/.mvn"
fi

# --- Generar settings.xml local si no existe ---
if [[ ! -f "$MAVEN_USER_SETTINGS" ]]; then
  cat >"$MAVEN_USER_SETTINGS" <<EOF
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">
  <localRepository>$MVN_LOCAL_REPO</localRepository>
</settings>
EOF
fi

# --- maven.config (1 argumento por línea; robusto) ---
_MVN_CFG="-s
$MAVEN_USER_SETTINGS
-Dmaven.repo.local=$MVN_LOCAL_REPO"

printf "%s\n" "$_MVN_CFG" > "$BASE/.mvn/maven.config"
if [[ -d "$IDEMPIERE_HOME" ]]; then
  printf "%s\n" "$_MVN_CFG" > "$IDEMPIERE_HOME/.mvn/maven.config"
fi

# --- Flags/opts comunes ---
export JAVA_TOOL_OPTIONS="-Djava.awt.headless=true"
export MAVEN_OPTS="${MAVEN_OPTS-} -Dmaven.repo.local=$MVN_LOCAL_REPO"

# --- Wrappers ejecutables (mejor que alias dentro de direnv) ---
BIN_DIR="$BASE/.local-bin"
mkdir -p "$BIN_DIR"

# mvn wrapper (usa el Maven del entorno si existe)
cat > "$BIN_DIR/mvn" <<EOF
#!/bin/bash
if [[ ! -x "$MAVEN_HOME/bin/mvn" ]]; then
  echo "❌ Maven no encontrado en: $MAVEN_HOME/bin/mvn"
  echo "   Copia/descomprime Maven dentro de: $MAVEN_HOME"
  exit 1
fi
exec "$MAVEN_HOME/bin/mvn" -s "$MAVEN_USER_SETTINGS" -Dmaven.repo.local="$MVN_LOCAL_REPO" "\$@"
EOF

# eclipse-choose wrapper (usa Eclipse del entorno si existe)
cat > "$BIN_DIR/eclipse-choose" <<EOF
#!/bin/bash
if [[ ! -x "$ECLIPSE_HOME/eclipse" ]]; then
  echo "❌ Eclipse no encontrado en: $ECLIPSE_HOME/eclipse"
  echo "   Copia/descomprime Eclipse dentro de: $ECLIPSE_HOME"
  exit 1
fi
if [[ -z "\${JAVA_HOME:-}" ]] || [[ ! -x "$JAVA_HOME/bin/java" ]]; then
  echo "❌ JAVA_HOME inválido: \${JAVA_HOME:-<vacío>}"
  exit 1
fi
exec "$ECLIPSE_HOME/eclipse" \\
  -vm "$JAVA_HOME/bin/java" \\
  -Declipse.p2.data.area="$ECLIPSE_P2" \\
  -Duser.home="$BASE" \\
  -data @noDefault
EOF

# eclipse-here wrapper
cat > "$BIN_DIR/eclipse-here" <<EOF
#!/bin/bash
if [[ ! -x "$ECLIPSE_HOME/eclipse" ]]; then
  echo "❌ Eclipse no encontrado en: $ECLIPSE_HOME/eclipse"
  echo "   Copia/descomprime Eclipse dentro de: $ECLIPSE_HOME"
  exit 1
fi
if [[ -z "\${JAVA_HOME:-}" ]] || [[ ! -x "$JAVA_HOME/bin/java" ]]; then
  echo "❌ JAVA_HOME inválido: \${JAVA_HOME:-<vacío>}"
  exit 1
fi
exec "$ECLIPSE_HOME/eclipse" \\
  -vm "$JAVA_HOME/bin/java" \\
  -Declipse.p2.data.area="$ECLIPSE_P2" \\
  -Duser.home="$BASE" \\
  -data "$ECLIPSE_WORKSPACE"
EOF

chmod +x "$BIN_DIR/"*

# --- PATH (prepend seguro) ---
PATH_add "$BIN_DIR"           # wrapper mvn/eclipse-*
PATH_add "$JAVA_HOME/bin"     # si existe
PATH_add "$MAVEN_HOME/bin"    # si existe
PATH_add "$ECLIPSE_HOME"      # opcional
# PATH_add previene errores típicos de sobreescribir PATH [web:110]

# ==========================
#  Panel visual de estado
# ==========================
if command -v tput >/dev/null 2>&1; then
  _bold=$(tput bold); _dim=$(tput dim); _reset=$(tput sgr0)
  _c1=$(tput setaf 6); _c2=$(tput setaf 2); _c3=$(tput setaf 5); _c4=$(tput setaf 4); _cY=$(tput setaf 3)
else
  _bold=''; _dim=''; _reset=''; _c1=''; _c2=''; _c3=''; _c4=''; _cY=''
fi

_print_kv () { printf "  ${_bold}%-16s${_reset} %s\n" "$1" "$2"; }

hr_top="┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓"
hr_mid="┣━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┫"
hr_bot="┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛"

echo ""
echo "${_c1}${hr_top}${_reset}"
printf "┃ ${_bold}iDempiere 8.2 — Entorno cargado${_reset} %-18s ┃\n" ""
echo "${_c1}${hr_mid}${_reset}"
_print_kv "BASE"            "${_c2}$BASE${_reset}"
_print_kv "JAVA_HOME"       "${_c2}${JAVA_HOME:-<no>}${_reset}"
_print_kv "MAVEN_HOME"      "${_c2}$MAVEN_HOME${_reset}"
_print_kv "Repo Maven"      "${_c3}$MVN_LOCAL_REPO${_reset}"
_print_kv "Settings.xml"    "${_c3}$MAVEN_USER_SETTINGS${_reset}"
_print_kv "Eclipse"         "${_c4}$ECLIPSE_HOME${_reset}"
_print_kv "Workspace"       "${_c4}$ECLIPSE_WORKSPACE${_reset}"
_print_kv "Eclipse p2"      "${_c4}$ECLIPSE_P2${_reset}"
_print_kv "IDEMPIERE_HOME"  "${_cY}$IDEMPIERE_HOME${_reset}"
_print_kv "IDEMPIERE_REPO"  "${_cY}$IDEMPIERE_REPO${_reset}"
echo "${_c1}${hr_bot}${_reset}"
echo "💡 ${_dim}Comandos:${_reset} ${_bold}eclipse-choose${_reset} | ${_bold}eclipse-here${_reset} | ${_bold}mvn -v${_reset}"
echo ""
